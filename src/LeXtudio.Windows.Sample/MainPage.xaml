<Page x:Class="LeXtudio.Windows.Sample.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:local="using:LeXtudio.Windows.Sample"
      mc:Ignorable="d">

    <Grid x:Name="Root">
        <NavigationView x:Name="NavView"
                        PaneDisplayMode="Left"
                        OpenPaneLength="260"
                        IsSettingsVisible="False"
                        IsBackButtonVisible="Collapsed"
                        IsPaneToggleButtonVisible="False"
                        SelectionChanged="OnScenarioSelected"
                        Loaded="OnNavLoaded">
            <NavigationView.Header>
                <StackPanel Orientation="Horizontal" Spacing="16">
                    <TextBlock Text="LeXtudio.Windows DataGrid"
                               VerticalAlignment="Center"
                               FontSize="18" />
                    <Button x:Name="ThemeButton"
                            VerticalAlignment="Center"
                            Click="OnToggleTheme">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE793;" />
                            <TextBlock Text="Toggle Theme" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <DropDownButton VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <PathIcon Data="M8.00662 0C3.57917 0 0 3.66665 0 8.2028C0 11.8288 2.29329 14.8981 5.4747 15.9844C5.87246 16.0661 6.01816 15.8079 6.01816 15.5908C6.01816 15.4006 6.00505 14.7488 6.00505 14.0696C3.7778 14.5586 3.31399 13.0918 3.31399 13.0918C2.95606 12.1411 2.42572 11.8968 2.42572 11.8968C1.69674 11.3943 2.47882 11.3943 2.47882 11.3943C3.28744 11.4486 3.71175 12.2363 3.71175 12.2363C4.42745 13.4856 5.58074 13.1326 6.04471 12.9153C6.11092 12.3856 6.32315 12.0189 6.5485 11.8153C4.77211 11.6251 2.90312 10.919 2.90312 7.76813C2.90312 6.8718 3.22107 6.13847 3.72486 5.56814C3.64538 5.36448 3.36693 4.52231 3.80451 3.39515C3.80451 3.39515 4.48055 3.17782 6.00488 4.23715C6.6575 4.05759 7.33054 3.96625 8.00662 3.96548C8.68266 3.96548 9.37181 4.06065 10.0082 4.23715C11.5327 3.17782 12.2087 3.39515 12.2087 3.39515C12.6463 4.52231 12.3677 5.36448 12.2882 5.56814C12.8053 6.13847 13.1101 6.8718 13.1101 7.76813C13.1101 10.919 11.2411 11.6115 9.45146 11.8153C9.74318 12.0733 9.99492 12.5621 9.99492 13.3363C9.99492 14.4363 9.98181 15.3191 9.98181 15.5906C9.98181 15.8079 10.1277 16.0661 10.5253 15.9846C13.7067 14.8979 16 11.8288 16 8.2028C16.0131 3.66665 12.4208 0 8.00662 0Z" />
                            <TextBlock Text="Source" VerticalAlignment="Center" />
                        </StackPanel>
                        <DropDownButton.Flyout>
                            <Flyout>
                                <StackPanel>
                                    <HyperlinkButton Margin="-12,4,-12,0"
                                                     HorizontalAlignment="Stretch"
                                                     HorizontalContentAlignment="Left"
                                                     NavigateUri="https://github.com/lextudio/WindowsShims/blob/main/src/LeXtudio.Windows.Sample/MainPage.xaml">
                                        <TextBlock Text="MainPage.xaml" />
                                    </HyperlinkButton>
                                    <HyperlinkButton Margin="-12,4,-12,0"
                                                     HorizontalAlignment="Stretch"
                                                     HorizontalContentAlignment="Left"
                                                     NavigateUri="https://github.com/lextudio/WindowsShims/blob/main/src/LeXtudio.Windows.Sample/MainPage.cs">
                                        <TextBlock Text="MainPage.cs" />
                                    </HyperlinkButton>
                                    <HyperlinkButton Margin="-12,4,-12,0"
                                                     HorizontalAlignment="Stretch"
                                                     HorizontalContentAlignment="Left"
                                                     NavigateUri="https://github.com/lextudio/WindowsShims/blob/main/src/LeXtudio.Windows.Sample/ScenarioHost.xaml">
                                        <TextBlock Text="ScenarioHost.xaml" />
                                    </HyperlinkButton>
                                    <HyperlinkButton Margin="-12,4,-12,0"
                                                     HorizontalAlignment="Stretch"
                                                     HorizontalContentAlignment="Left"
                                                     NavigateUri="https://github.com/lextudio/WindowsShims/blob/main/src/LeXtudio.Windows.Sample/ScenarioHost.xaml.cs">
                                        <TextBlock Text="ScenarioHost.xaml.cs" />
                                    </HyperlinkButton>
                                    <HyperlinkButton Margin="-12,4,-12,0"
                                                     HorizontalAlignment="Stretch"
                                                     HorizontalContentAlignment="Left"
                                                     NavigateUri="https://github.com/lextudio/WindowsShims/blob/main/tests/DataGrid.TestScenarios/DataGridScenarios.cs">
                                        <TextBlock Text="DataGridScenarios.cs" />
                                    </HyperlinkButton>
                                </StackPanel>
                            </Flyout>
                        </DropDownButton.Flyout>
                    </DropDownButton>
                </StackPanel>
            </NavigationView.Header>

            <ContentControl x:Name="ScenarioContent"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch" />
        </NavigationView>

        <StackPanel x:Name="LoadingOverlay"
                    Visibility="Collapsed"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Spacing="16">
            <ProgressRing IsActive="True" Width="50" Height="50" />
            <TextBlock Text="Preparing demo data..."
                       Style="{StaticResource SubtitleTextBlockStyle}" />
        </StackPanel>
    </Grid>
</Page>
